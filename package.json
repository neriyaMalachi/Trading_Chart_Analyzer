{
  "name": "trading-chart-analyzer",
  "version": "0.1.0",
  "private": true,
  "description": "Trading Chart Analyzer — educational AI chart analysis. We explain. You decide.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many --target=build --all",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "typecheck": "nx run-many --target=typecheck --all",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "mobile": "nx run mobile:start",
    "api": "nx run api:start:dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "eslint": "10.3.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import-x": "^4.16.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.2",
    "nx": "22.7.1",
    "prettier": "3.8.3",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  }
}