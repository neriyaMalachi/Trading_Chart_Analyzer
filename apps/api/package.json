{
  "name": "@tca/api",
  "version": "0.1.0",
  "private": true,
  "description": "Trading Chart Analyzer — NestJS API",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build --webpack",
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:dev": "ts-node-dev -r tsconfig-paths/register --respawn src/main.ts",
    "start:debug": "ts-node -r tsconfig-paths/register --inspect src/main.ts",
    "start:prod": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.95.0",
    "@aws-sdk/client-s3": "3.1044.0",
    "@aws-sdk/s3-request-presigner": "3.1044.0",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/throttler": "6.5.0",
    "@tca/constants": "*",
    "@tca/types": "*",
    "@tca/validators": "*",
    "bcrypt": "^5.1.1",
    "drizzle-orm": "0.45.2",
    "helmet": "8.1.0",
    "nestjs-zod": "5.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "22.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "11.1.19",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.30.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
